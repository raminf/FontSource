# Copy to `.env` for local tooling only. CI uses GitHub repository secrets with the same names.
# Never commit real values.

# --- Chrome Web Store (OAuth client + refresh token; see chrome-webstore-upload-keys guide) ---
# https://github.com/fregante/chrome-webstore-upload-keys
CHROME_EXTENSION_ID=
CHROME_CLIENT_ID=
CHROME_CLIENT_SECRET=
CHROME_REFRESH_TOKEN=
# Local publish script only; CI sets this from the Makefile VERSION:
# CHROME_ZIP_PATH=/absolute/path/to/FontSource/artifacts/fontsource-chrome-1.0.0.zip

# --- Firefox / AMO (JWT credentials; used by mozilla/web-ext as WEB_EXT_*) ---
# From https://addons.mozilla.org/developers/addon/api/key/
# Your add-on must declare a stable gecko id (e.g. applications.gecko.id) for listed updates.
WEB_EXT_API_KEY=
WEB_EXT_API_SECRET=

# --- Safari / Mac App Store (optional; automated upload is not implemented) ---
# If all three are set, scripts/publish-safari.sh can be extended to call notarytool / Transporter.
# Normal path: make package-safari, open safari/FontSource in Xcode, Product > Archive, distribute.
ASC_ISSUER_ID=
ASC_KEY_ID=
# Base64 of the .p8 private key contents, or the PEM itself on one line (match your script).
ASC_KEY_P8=
