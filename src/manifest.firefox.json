{
  "manifest_version": 2,
  "name": "FontSource",
  "version": "1.0.3",
  "description": "Detect fonts, their sources, and license information on any website",
  "browser_specific_settings": {
    "gecko": {
      "id": "fontsource@github.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "websiteActivity"
        ]
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "scripts": [
      "lib/font-face-remote.js",
      "background.firefox.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "http://*/*",
        "https://*/*"
      ],
      "js": [
        "lib/font-detection.js",
        "content.js"
      ],
      "run_at": "document_end"
    }
  ],
  "browser_action": {
    "default_popup": "popup/popup.firefox.html",
    "default_title": "FontSource - Font Detector",
    "default_icon": {
      "16": "icons/icon16.png",
      "24": "icons/icon24.png",
      "32": "icons/icon32.png"
    }
  },
  "web_accessible_resources": [
    "lib/font-detection.js",
    "content.js"
  ]
}
